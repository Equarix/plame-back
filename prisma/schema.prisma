generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  USER
}

model User {
  userId   Int     @id @default(autoincrement())
  name     String
  lastName String
  username String
  password String
  role     Role    @default(USER)
  status   Boolean @default(true)
}

model TEmpresa {
  companyId Int        @id @default(autoincrement())
  name      String
  ruc       String
  address   String
  status    Boolean    @default(true)
  tpersonas TPersona[]
}

enum CategoriaPersona {
  TRABAJADOR
  PENSIONISTA
  PERSONAL_FORMACION_LABORAL
  PERSONAL_TERCERO
}

enum TipoTrabajador {
  EJECUTIVO
  OBRERO
  EMPLEADO
  TRABAJADOR_PORTUARIO
  PRACTICANTE_SENATI
  CONSTRUCTOR_CIVIL
  PILOTO_COPILOTO
  MARITMO_FLOVIAL_LACUSTRE
  PERIODISTA
  TRAB_INDUSTRIA_CUERO
}

enum RegimenLaboral {
  D_LEG_728
  MICROEMPRESA
  AGRARIO
  MINEROS
  OTROS
}

enum TipoContrato {
  PLAZO_INDETERMINADO
  TIEMPO_PARCIAL
  INICIO_INCREMEN_ACTIVIDAD
  NECES_MERCADO
  RECONV_EMPRESARIAL
  OCASIONAL
  SUPLENCIA
  EMERGENCIA
  OBRA_DETERMINADA
  INTERMINENTE
  OTRO
}

enum TipoPago {
  EFECTIVO
  DEPOSITO_BANCARIO
  OTRO
}

enum PeriodoIngreso {
  MENSUAL
  QUINCENAL
  SEMANAL
  DIARIO
  OTRO
}

model Ocupacion {
  ocupacionId Int        @id @default(autoincrement())
  name        String
  tpersonas   TPersona[]
  status      Boolean    @default(true)
  createdAt   DateTime   @default(now())
}

model Entidades {
  entidadId Int        @id @default(autoincrement())
  name      String
  status    Boolean    @default(true)
  createdAt DateTime   @default(now())
  tpersonas TPersona[]
}

enum RegimenSalud {
  ESSALUD_REGULAR
  ESALUD_REGULAR_EPS
  ESSALUD_AGRICOLA
  SIS_MICROEMPRESA
}

enum RegimenPensionario {
  SISTEMA_NACIONAL_PENSIONES
  SPP_INTEGRA
  SPP_HORIZONTE
  SPP_PROFUNTO
  SPP_PRIMA
  SPP_HABITAT
  SIN_REGIMEN_PENSIONARIO
}

model SituacionesEducativas {
  situacionEducativaId Int        @id @default(autoincrement())
  nombre               String
  requiereEstudios     Boolean
  estado               Boolean    @default(true)
  createdAt            DateTime   @default(now())
  tpersonas            TPersona[]
}

model Persona {
  personaId       Int         @id @default(autoincrement())
  dni             String
  fechaNacimiento DateTime
  nombres         String
  apellidoPaterno String
  apellidoMaterno String
  sexo            String
  estadoCivil     String
  nacionalidad    String
  estado          Boolean     @default(true)
  createdAt       DateTime    @default(now())
  tpersonas       TPersona[]
  direcciones     Direccion[]
}

model Pais {
  idPais        Int            @id @default(autoincrement())
  pais          String
  nacionalidad  String
  departamentos Departamento[]
}

model Departamento {
  idDepartamento Int         @id @default(autoincrement())
  departamento   String
  idPais         Int
  pais           Pais        @relation(fields: [idPais], references: [idPais])
  provincias     Provincia[]
  direccions     Direccion[]
}

model Provincia {
  idProvincia    Int          @id @default(autoincrement())
  provincia      String
  idDepartamento Int
  departamento   Departamento @relation(fields: [idDepartamento], references: [idDepartamento])
  distritos      Distrito[]
  direccions     Direccion[]
}

model Distrito {
  idDistrito  Int         @id @default(autoincrement())
  distrito    String
  idProvincia Int
  provincia   Provincia   @relation(fields: [idProvincia], references: [idProvincia])
  direccions  Direccion[]
}

enum TipoVia {
  AVENIDA
  CALLE
  JIRON
  PASAJE
  OTRO
}

enum TipoZona {
  URBANA
  RURAL
  OTRO
}

model Direccion {
  direccionId      Int          @id @default(autoincrement())
  departamentoId   Int
  provinciaId      Int
  distritoId       Int
  departamento     Departamento @relation(fields: [departamentoId], references: [idDepartamento])
  provincia        Provincia    @relation(fields: [provinciaId], references: [idProvincia])
  distrito         Distrito     @relation(fields: [distritoId], references: [idDistrito])
  tipoVia          TipoVia
  persona          Persona?     @relation(fields: [personaPersonaId], references: [personaId])
  personaPersonaId Int?
  nombreVia        String
  numero           String
  dpto             String?
  interior         String?
  manzana          String?
  lote             String?
  block            String?
  etapa            String?
  tipoZona         TipoZona
  nombreZona       String
  referencia       String?
  refiereEssalud   Boolean      @default(false)
}

enum JornadaLaboral {
  MAXIMA
  ACUMULATIVA
  NOCTURNO
}

model TPersona {
  tPersonaId               Int                   @id @default(autoincrement())
  personaId                Int
  persona                  Persona               @relation(fields: [personaId], references: [personaId])
  categoria                CategoriaPersona
  telefono                 String
  email                    String
  periodoInicio            DateTime
  periodoFin               DateTime?
  motivoBaja               String?
  tipoTrabajador           TipoTrabajador
  fechaInicio              DateTime
  motivoBajaTrabajador     String?
  regimenLaboral           RegimenLaboral
  otroRegimenLaboral       String?
  ocupacionId              Int
  ocupacion                Ocupacion             @relation(fields: [ocupacionId], references: [ocupacionId])
  tipoContrato             TipoContrato
  otroTipoContrato         String?
  tipoPago                 TipoPago
  otroTipoPago             String?
  periodoIngreso           PeriodoIngreso
  otroPeriodoIngreso       String?
  entidadId                Int?
  entidad                  Entidades?            @relation(fields: [entidadId], references: [entidadId])
  cuentaBancaria           String?
  montoRemuneracionInicial Float
  codlocal                 String?
  local                    String?
  jornadaLaboral           JornadaLaboral?
  situacionEspecial        String?
  discapacidad             Boolean               @default(false)
  sindicalizado            Boolean               @default(false)
  regimenSalud             RegimenSalud
  fechaInicioSalud         DateTime
  fechaFinSalud            DateTime?
  regimenPensionario       RegimenPensionario
  fechaInicioPensionario   DateTime
  fechaFinPensionario      DateTime?
  CUSPP                    String?
  sctr                     Boolean               @default(false)
  situacionEducativaId     Int
  situacionEducativa       SituacionesEducativas @relation(fields: [situacionEducativaId], references: [situacionEducativaId])
  estudios                 Estudios[]
  quintaCategoriaExonerada Boolean               @default(false)
  evitaDobleImposicion     Boolean               @default(false)
  tempresa                 TEmpresa?             @relation(fields: [tEmpresaCompanyId], references: [companyId])
  tEmpresaCompanyId        Int?
}

enum FormacionCompleta {
  SUPERIOR_COMPLETA
  UNIVERSITARIA_COMPLETA
}

enum TipoEducacion {
  INSTITUTO
  UNIVERSIDAD
  POLICIALES
  NO_ESPECIFICA
}

model Estudios {
  estudioId         Int               @id @default(autoincrement())
  tPersonaId        Int
  tPersona          TPersona          @relation(fields: [tPersonaId], references: [tPersonaId])
  formacionCompleta FormacionCompleta
  estudioPeru       Boolean
  privado           Boolean
  tipoEducacion     TipoEducacion
  nombreInstitucion String
  nombreCarrera     String
  añoEgreso        Int
}
