generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  USER
}

model User {
  userId    Int        @id @default(autoincrement())
  name      String
  lastName  String
  username  String
  password  String
  role      Role       @default(USER)
  status    Boolean    @default(true)
  tpersonas TPersona[]
}

model TEmpresa {
  companyId          Int                @id @default(autoincrement())
  name               String
  ruc                String
  address            String
  status             Boolean            @default(true)
  tpersonas          TPersona[]
  plameDeclaraciones PlameDeclaracion[]
}

enum CategoriaPersona {
  TRABAJADOR
  PENSIONISTA
  PERSONAL_FORMACION_LABORAL
  PERSONAL_TERCERO
}

enum TipoTrabajador {
  EJECUTIVO
  OBRERO
  EMPLEADO
  TRABAJADOR_PORTUARIO
  PRACTICANTE_SENATI
  CONSTRUCTOR_CIVIL
  PILOTO_COPILOTO
  MARITMO_FLOVIAL_LACUSTRE
  PERIODISTA
  TRAB_INDUSTRIA_CUERO
}

enum RegimenLaboral {
  D_LEG_728
  MICROEMPRESA
  AGRARIO
  MINEROS
  OTROS
}

enum TipoContrato {
  PLAZO_INDETERMINADO
  TIEMPO_PARCIAL
  INICIO_INCREMEN_ACTIVIDAD
  NECES_MERCADO
  RECONV_EMPRESARIAL
  OCASIONAL
  SUPLENCIA
  EMERGENCIA
  OBRA_DETERMINADA
  INTERMINENTE
  OTRO
}

enum TipoPago {
  EFECTIVO
  DEPOSITO_BANCARIO
  OTRO
}

enum PeriodoIngreso {
  MENSUAL
  QUINCENAL
  SEMANAL
  DIARIO
  OTRO
}

model Ocupacion {
  ocupacionId Int        @id @default(autoincrement())
  name        String
  tpersonas   TPersona[]
  status      Boolean    @default(true)
  createdAt   DateTime   @default(now())
}

model Entidades {
  entidadId Int        @id @default(autoincrement())
  name      String
  status    Boolean    @default(true)
  createdAt DateTime   @default(now())
  tpersonas TPersona[]
}

enum RegimenSalud {
  ESSALUD_REGULAR
  ESALUD_REGULAR_EPS
  ESSALUD_AGRICOLA
  SIS_MICROEMPRESA
}

enum RegimenPensionario {
  SISTEMA_NACIONAL_PENSIONES
  SPP_INTEGRA
  SPP_HORIZONTE
  SPP_PROFUNTO
  SPP_PRIMA
  SPP_HABITAT
  SIN_REGIMEN_PENSIONARIO
}

model SituacionesEducativas {
  situacionEducativaId Int        @id @default(autoincrement())
  nombre               String
  requiereEstudios     Boolean
  estado               Boolean    @default(true)
  createdAt            DateTime   @default(now())
  tpersonas            TPersona[]
}

model Persona {
  personaId       Int         @id @default(autoincrement())
  dni             String
  fechaNacimiento DateTime
  nombres         String
  apellidoPaterno String
  apellidoMaterno String
  sexo            String
  estadoCivil     String
  nacionalidad    String
  estado          Boolean     @default(true)
  createdAt       DateTime    @default(now())
  tpersonas       TPersona[]
  direcciones     Direccion[]
}

model Pais {
  idPais        Int            @id @default(autoincrement())
  pais          String
  nacionalidad  String
  departamentos Departamento[]
}

model Departamento {
  idDepartamento Int         @id @default(autoincrement())
  departamento   String
  idPais         Int
  pais           Pais        @relation(fields: [idPais], references: [idPais])
  provincias     Provincia[]
  direccions     Direccion[]
}

model Provincia {
  idProvincia    Int          @id @default(autoincrement())
  provincia      String
  idDepartamento Int
  departamento   Departamento @relation(fields: [idDepartamento], references: [idDepartamento])
  distritos      Distrito[]
  direccions     Direccion[]
}

model Distrito {
  idDistrito  Int         @id @default(autoincrement())
  distrito    String
  idProvincia Int
  provincia   Provincia   @relation(fields: [idProvincia], references: [idProvincia])
  direccions  Direccion[]
}

enum TipoVia {
  AVENIDA
  CALLE
  JIRON
  PASAJE
  OTRO
}

enum TipoZona {
  URBANA
  RURAL
  OTRO
}

model Direccion {
  direccionId      Int          @id @default(autoincrement())
  departamentoId   Int
  provinciaId      Int
  distritoId       Int
  departamento     Departamento @relation(fields: [departamentoId], references: [idDepartamento])
  provincia        Provincia    @relation(fields: [provinciaId], references: [idProvincia])
  distrito         Distrito     @relation(fields: [distritoId], references: [idDistrito])
  tipoVia          TipoVia
  persona          Persona?     @relation(fields: [personaPersonaId], references: [personaId])
  personaPersonaId Int?
  nombreVia        String
  numero           String
  dpto             String?
  interior         String?
  manzana          String?
  lote             String?
  block            String?
  etapa            String?
  tipoZona         TipoZona
  nombreZona       String
  referencia       String?
  refiereEssalud   Boolean      @default(false)
}

enum JornadaLaboral {
  MAXIMA
  ACUMULATIVA
  NOCTURNO
}

model TPersona {
  tPersonaId               Int                   @id @default(autoincrement())
  personaId                Int
  persona                  Persona               @relation(fields: [personaId], references: [personaId])
  categoria                CategoriaPersona
  telefono                 String
  email                    String
  periodoInicio            DateTime
  periodoFin               DateTime?
  motivoBaja               String?
  tipoTrabajador           TipoTrabajador
  fechaInicio              DateTime
  motivoBajaTrabajador     String?
  regimenLaboral           RegimenLaboral
  otroRegimenLaboral       String?
  ocupacionId              Int
  ocupacion                Ocupacion             @relation(fields: [ocupacionId], references: [ocupacionId])
  tipoContrato             TipoContrato
  otroTipoContrato         String?
  tipoPago                 TipoPago
  otroTipoPago             String?
  periodoIngreso           PeriodoIngreso
  otroPeriodoIngreso       String?
  entidadId                Int?
  entidad                  Entidades?            @relation(fields: [entidadId], references: [entidadId])
  cuentaBancaria           String?
  montoRemuneracionInicial Float
  codlocal                 String?
  local                    String?
  jornadaLaboral           JornadaLaboral?
  situacionEspecial        String?
  discapacidad             Boolean               @default(false)
  sindicalizado            Boolean               @default(false)
  regimenSalud             RegimenSalud
  fechaInicioSalud         DateTime
  fechaFinSalud            DateTime?
  regimenPensionario       RegimenPensionario
  fechaInicioPensionario   DateTime
  fechaFinPensionario      DateTime?
  CUSPP                    String?
  sctr                     Boolean               @default(false)
  pension                  Pensiones?
  salud                    Salud?
  fechaInicioSaludPension  DateTime?
  fechaFinSaludPension     DateTime?
  situacionEducativaId     Int
  situacionEducativa       SituacionesEducativas @relation(fields: [situacionEducativaId], references: [situacionEducativaId])
  estudios                 Estudios[]
  quintaCategoriaExonerada Boolean               @default(false)
  evitaDobleImposicion     Boolean               @default(false)
  tempresa                 TEmpresa?             @relation(fields: [tEmpresaCompanyId], references: [companyId])
  tEmpresaCompanyId        Int?
  createAt                 DateTime              @default(now())
  userId                   Int
  user                     User                  @relation(fields: [userId], references: [userId])
  fechaIngreso             DateTime
  plameDetalles            PlameDetallePersona[]
}

enum Pensiones {
  ONP
  PRIVADO
}

enum Salud {
  ESSALUD
  EPS
}

enum FormacionCompleta {
  SUPERIOR_COMPLETA
  UNIVERSITARIA_COMPLETA
}

enum TipoEducacion {
  INSTITUTO
  UNIVERSIDAD
  POLICIALES
  NO_ESPECIFICA
}

model Estudios {
  estudioId         Int               @id @default(autoincrement())
  tPersonaId        Int
  tPersona          TPersona          @relation(fields: [tPersonaId], references: [tPersonaId])
  formacionCompleta FormacionCompleta
  estudioPeru       Boolean
  privado           Boolean
  tipoEducacion     TipoEducacion
  nombreInstitucion String
  nombreCarrera     String
  añoEgreso        Int
}

model PlameDeclaracion {
  plameDeclaracionId Int                   @id @default(autoincrement())
  companyId          Int
  tempresa           TEmpresa              @relation(fields: [companyId], references: [companyId])
  periodo            String
  sustitutoria       Boolean               @default(false)
  numeroOrden        String?
  fechaPresentacion  DateTime?
  estado             String                @default("En Proceso")
  totalNetoAPagar    Float                 @default(0.0)
  createdAt          DateTime              @default(now())
  detalles           PlameDetallePersona[]
}

model PlameDetallePersona {
  detalleId          Int                     @id @default(autoincrement())
  plameDeclaracionId Int
  plameDeclaracion   PlameDeclaracion        @relation(fields: [plameDeclaracionId], references: [plameDeclaracionId], onDelete: Cascade)
  tPersonaId         Int
  tPersona           TPersona                @relation(fields: [tPersonaId], references: [tPersonaId])
  diasLaborados      Int                     @default(30)
  diasSubsidiados    Int                     @default(0)
  diasNoLaborados    Int                     @default(0)
  horasOrdinarias    String                  @default("00:00")
  horasSobretiempo   String                  @default("00:00")
  ingresos           PlameDetalleIngreso[]
  descuentos         PlameDetalleDescuento[]
  tributos           PlameDetalleTributo[]
  createdAt          DateTime                @default(now())
}

model PlameDetalleIngreso {
  ingresoId Int                 @id @default(autoincrement())
  detalleId Int
  detalle   PlameDetallePersona @relation(fields: [detalleId], references: [detalleId], onDelete: Cascade)
  code      String
  name      String
  devengado Float               @default(0.0)
  pagado    Float               @default(0.0)
}

model PlameDetalleDescuento {
  descuentoId Int                 @id @default(autoincrement())
  detalleId   Int
  detalle     PlameDetallePersona @relation(fields: [detalleId], references: [detalleId], onDelete: Cascade)
  code        String
  name        String
  monto       Float               @default(0.0)
}

model PlameDetalleTributo {
  tributoId Int                 @id @default(autoincrement())
  detalleId Int
  detalle   PlameDetallePersona @relation(fields: [detalleId], references: [detalleId], onDelete: Cascade)
  code      String
  name      String
  base      Float               @default(0.0)
  monto     Float               @default(0.0)
}
